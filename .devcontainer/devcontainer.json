{
  "name": "F# para Contadores",
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0",
  "hostRequirements": { "cpus": 4 },
  "customizations": {
    "vscode": {
      "extensions": [
        "Ionide.Ionide-fsharp"
      ],
      "settings": {
        "FSharp.inlayHints.enabled": true,
        "FSharp.inlayHints.typeAnnotations": true,
        "FSharp.inlayHints.parameterNames": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "onCreateCommand": "echo 'printfn \"warmup ok\"' | dotnet fsi --use:/dev/stdin",
  "postCreateCommand": "dotnet --list-sdks"
}
